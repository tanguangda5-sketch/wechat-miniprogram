.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f6faf4 0%, #edf5ea 100%);
  padding-bottom: 220rpx;
  box-sizing: border-box;
}

.heroWrap {
  position: relative;
  width: 100%;
  height: 520rpx;
  overflow: hidden;
}

.heroSwiper {
  width: 100%;
  height: 100%;
}

.hero {
  width: 100%;
  height: 100%;
  display: block;
}

.heroMask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(20, 20, 20, 0.28) 0%, rgba(20, 20, 20, 0.08) 36%, rgba(20, 20, 20, 0) 68%);
  pointer-events: none;
}

.customNav {
  position: fixed;
  left: 24rpx;
  right: auto;
  top: 0;
  padding-left: 0;
  padding-right: 0;
  z-index: 20;
  pointer-events: none;
}

.backBtn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(14, 38, 47, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
}

.backArrow {
  width: 22rpx;
  height: 22rpx;
  border-left: 4rpx solid #ffffff;
  border-bottom: 4rpx solid #ffffff;
  transform: rotate(45deg);
  margin-left: 8rpx;
}

.content {
  position: relative;
  z-index: 1;
  margin-top: 34rpx;
  padding: 8rpx 24rpx 32rpx;
}

.title {
  font-size: 48rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1f2a1f;
}

.summary {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #667566;
}

.metaRow {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.metaPrimary,
.metaTag,
.chip {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.metaPrimary {
  background: #edf5ea;
  color: #57984a;
}

.metaTag {
  background: rgba(255, 255, 255, 0.86);
  color: #667566;
}

.infoGrid {
  margin-top: 26rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.infoCard,
.listCard,
.detailCard,
.descriptionCard {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(87, 73, 54, 0.06);
}

.infoCard {
  padding: 22rpx 22rpx 24rpx;
}

.infoLabel {
  font-size: 24rpx;
  color: #8ea08b;
}

.infoValue {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #1f2a1f;
  font-weight: 600;
}

.priceValue {
  color: #57984a;
}

.infoSub {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #8ea08b;
}

.section {
  margin-top: 28rpx;
}

.sectionTitle {
  margin-bottom: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2a1f;
}

.chipWrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  background: rgba(255, 255, 255, 0.9);
  color: #667566;
}

.chipWarm {
  background: #edf5ea;
  color: #57984a;
}

.chipSoft {
  background: #edf5ea;
  color: #426046;
}

.listCard {
  padding: 16rpx 20rpx;
}

.bulletItem,
.timelineItem {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 12rpx 0;
}

.bulletDot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #57984a;
  flex-shrink: 0;
}

.bulletText,
.timelineText {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.7;
  color: #233123;
}

.timelineIndex {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #e6f2e3;
  color: #57984a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.detailCard {
  padding: 16rpx 22rpx;
}

.detailRow {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.detailRow:last-child {
  border-bottom: none;
}

.detailLabel {
  color: #8ea08b;
  font-size: 26rpx;
}

.detailValue {
  flex: 1;
  text-align: right;
  color: #233123;
  font-size: 26rpx;
}

.descriptionCard {
  padding: 24rpx;
  color: #233123;
  font-size: 28rpx;
  line-height: 1.85;
  white-space: pre-line;
}

.galleryScroll {
  white-space: nowrap;
}

.galleryImage {
  display: inline-block;
  width: 250rpx;
  height: 180rpx;
  margin-right: 16rpx;
  border-radius: 22rpx;
}

.bottomBar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
  padding: 8rpx 24rpx calc(env(safe-area-inset-bottom) + 8rpx);
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 28rpx rgba(55, 42, 26, 0.08);
  z-index: 999;
  pointer-events: auto;
}

.bottomMain {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.priceBox {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.priceLabel {
  font-size: 20rpx;
  color: #8ea08b;
}

.priceNum {
  font-size: 40rpx;
  font-weight: 700;
  color: #57984a;
}

.favoriteBtn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.favoriteIcon {
  width: 64rpx;
  height: 64rpx;
}

.bookBtn {
  min-width: 240rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  background: #57984a;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 0 28rpx;
}

.emptyState {
  padding: 80rpx 32rpx;
  text-align: center;
  color: #99a598;
  font-size: 28rpx;
}
