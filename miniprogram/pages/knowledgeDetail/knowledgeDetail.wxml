<view class="detail-page container-safe">
  <view class="loading-box" wx:if="{{loading}}">正在加载文章...</view>

  <block wx:elif="{{article}}">
    <image wx:if="{{article.cover}}" class="detail-cover" src="{{article.cover}}" mode="aspectFill"></image>
    <view wx:else class="detail-cover detail-cover-empty">封面待补图</view>
    <view class="detail-card">
      <view class="detail-title">{{article.title}}</view>
      <view class="meta-row">{{article.author}} · {{article.publishTime}}</view>
      <view class="meta-row light">{{article.wordCount}} 字 · {{article.views}} 阅读</view>
      <view class="tag-row">
        <block wx:for="{{article.tags}}" wx:key="*this">
          <text class="tag">{{item}}</text>
        </block>
      </view>

      <view class="summary-box">{{article.summary}}</view>

      <block wx:for="{{article.content}}" wx:key="index">
        <view wx:if="{{item.type === 'heading'}}" class="content-h2">{{item.text}}</view>
        <image wx:elif="{{item.type === 'image' && item.src}}" class="content-image" src="{{item.src}}" mode="widthFix"></image>
        <view wx:else class="content-p">{{item.text}}</view>
      </block>

      <view class="location-card" wx:if="{{article.location}}" bindtap="openMap">
        <view class="location-left">
          <view class="location-title">{{article.location.name}}</view>
          <view class="location-address">{{article.location.address}}</view>
        </view>
        <view class="location-right">查看地图</view>
      </view>

      <view class="comment-section">
        <view class="comment-head">评论 {{commentList.length}}</view>
        <view class="comment-input-wrap">
          <input
            class="comment-input"
            placeholder="写下你的评论..."
            value="{{commentInput}}"
            bindinput="onCommentInput"
          />
          <view class="comment-send" bindtap="submitComment">发送</view>
        </view>

        <block wx:if="{{commentList.length}}">
          <block wx:for="{{commentList}}" wx:key="index">
            <view class="comment-item">
              <view class="comment-user">{{item.user}}</view>
              <view class="comment-text">{{item.content}}</view>
              <view class="comment-time">{{item.time}}</view>
            </view>
          </block>
        </block>
        <view class="no-comment" wx:else>还没有评论，来抢沙发吧。</view>
      </view>
    </view>

    <view class="action-bar">
      <view class="action-item" bindtap="toggleLike">{{liked ? '已赞' : '点赞'}} {{article.likes}}</view>
      <view class="action-item favoriteAction" bindtap="toggleFavorite">
        <image class="favoriteActionIcon" src="{{favorited ? favoriteIconFilled : favoriteIcon}}" mode="aspectFit" />
        <text>{{favorited ? '已收藏' : '收藏'}} {{article.favorites}}</text>
      </view>
      <view class="action-item" bindtap="focusComment">评论 {{commentList.length}}</view>
      <button class="share-btn" open-type="share">转发 {{article.shareCount}}</button>
    </view>
  </block>

  <view class="empty-box" wx:else>文章不存在或已下线。</view>
</view>
