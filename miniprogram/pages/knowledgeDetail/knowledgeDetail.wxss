.detail-page {
  min-height: 100vh;
  background: #f7f4ef;
  padding-bottom: 140rpx;
}

.loading-box,
.empty-box {
  padding: 180rpx 40rpx;
  text-align: center;
  color: #8d8d8d;
  font-size: 28rpx;
}

.detail-cover {
  width: 100%;
  height: 420rpx;
  background: #e9edf1;
}

.detail-cover-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9c9184;
  font-size: 30rpx;
}

.detail-card {
  margin: -34rpx 24rpx 0;
  background: #fff;
  border-radius: 34rpx 34rpx 0 0;
  padding: 32rpx 28rpx 40rpx;
}

.detail-title {
  font-size: 42rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #2d2925;
}

.meta-row {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #6a6259;
}

.meta-row.light {
  color: #988d80;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #eef5ea;
  color: #5f8f4e;
  font-size: 22rpx;
}

.summary-box {
  margin: 24rpx 0;
  padding: 24rpx;
  background: #fbfaf8;
  border-radius: 24rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: #5f564d;
}

.content-h2 {
  margin-top: 30rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #2f2a25;
}

.content-p {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.95;
  color: #3e372f;
  text-align: justify;
}

.content-image {
  display: block;
  width: 100%;
  margin-top: 24rpx;
  border-radius: 24rpx;
  background: #e9edf1;
}

.location-card {
  margin-top: 34rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f4efe7;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.location-left {
  flex: 1;
  padding-right: 20rpx;
}

.location-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #3a332d;
}

.location-address {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7d7368;
}

.location-right {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #b78366;
  color: #fff;
  font-size: 24rpx;
}

.comment-section {
  margin-top: 36rpx;
}

.comment-head {
  font-size: 30rpx;
  font-weight: 700;
  color: #2f2a25;
}

.comment-input-wrap {
  margin-top: 18rpx;
  display: flex;
  gap: 16rpx;
}

.comment-input {
  flex: 1;
  background: #f7f4ef;
  border-radius: 999rpx;
  padding: 18rpx 26rpx;
  font-size: 26rpx;
}

.comment-send {
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: #6c9b57;
  color: #fff;
  font-size: 26rpx;
}

.comment-item {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #fbfaf8;
}

.comment-user {
  font-size: 26rpx;
  font-weight: 700;
  color: #2e2a26;
}

.comment-text {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #4e473f;
}

.comment-time {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9a9085;
}

.no-comment {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #9a9085;
}

.action-bar {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 999rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.08);
}

.action-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 999rpx;
  background: #f7f4ef;
  color: #4a433b;
  font-size: 24rpx;
}

.favoriteAction {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.favoriteActionIcon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.share-btn {
  flex: 1;
  margin: 0;
  padding: 16rpx 0;
  line-height: 1.3;
  border-radius: 999rpx;
  background: #b78366;
  color: #fff;
  font-size: 24rpx;
}

.share-btn::after {
  border: none;
}
