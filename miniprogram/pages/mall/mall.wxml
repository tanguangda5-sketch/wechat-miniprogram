<view class="page">
  <view class="searchWrap">
    <view class="searchBox">乡味商城</view>
  </view>

  <view class="goodsList">
    <view
      wx:for="{{goodsList}}"
      wx:key="id"
      class="goodsCard"
      data-id="{{item.id}}"
      bindtap="goProductDetail"
    >
      <image class="goodsImg" src="{{item.cover}}" mode="aspectFill"></image>
      <text class="goodsName">{{item.title}}</text>
      <view class="goodsBottom">
        <text class="goodsPrice">{{item.priceText}}</text>
        <text class="goodsSold">{{item.soldText}}</text>
      </view>
    </view>
  </view>
</view>
