.page { min-height:100vh; background:#fff; }
.notice { margin:24rpx; padding:20rpx 24rpx; border-radius:22rpx; background:#eef3ff; color:#5c6fa7; font-size:24rpx; line-height:1.7; }
.row { display:flex; align-items:center; padding:24rpx; border-top:1rpx solid #f5f5f5; }
.avatar { width:88rpx; height:88rpx; border-radius:50%; display:flex; align-items:center; justify-content:center; color:#fff; font-size:32rpx; font-weight:700; flex-shrink:0; }
.main { flex:1; margin-left:20rpx; min-width:0; }
.title { font-size:32rpx; font-weight:700; color:#111; }
.side { width:72rpx; display:flex; flex-direction:column; align-items:flex-end; justify-content:center; flex-shrink:0; }
.time { font-size:24rpx; color:#aaa; line-height:1; }
.preview { margin-top:10rpx; font-size:26rpx; color:#777; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.badge { min-width:34rpx; height:34rpx; margin-top:14rpx; padding:0 8rpx; border-radius:999rpx; background:#ff3b68; color:#fff; font-size:20rpx; line-height:34rpx; text-align:center; box-sizing:border-box; }
