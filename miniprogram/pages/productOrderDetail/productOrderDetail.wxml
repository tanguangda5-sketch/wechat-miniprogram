<view class="page" wx:if="{{detail}}">
  <view class="sectionCard">
    <view class="statusRow">
      <view class="statusTitle">{{detail.displayStatusText}}</view>
      <view wx:if="{{detail.displayStatusKey === 'pending_payment'}}" class="countdown">剩余支付时间 {{countdownText}}</view>
    </view>

    <view class="amountMain">{{detail.payAmountText}}</view>
    <view class="metaLine">订单号：{{detail.orderNo}}</view>
    <view class="metaLine" wx:if="{{detail.createdAtText}}">下单时间：{{detail.createdAtText}}</view>
    <view class="metaLine" wx:if="{{detail.paidAtText}}">支付时间：{{detail.paidAtText}}</view>
    <view class="metaLine" wx:if="{{detail.shippedAtText}}">发货时间：{{detail.shippedAtText}}</view>
  </view>

  <view class="sectionCard" wx:if="{{detail.addressSnapshot}}">
    <view class="sectionTitle">收货地址</view>
    <view class="receiverRow">
      <text class="receiver">{{detail.addressSnapshot.receiverName}}</text>
      <text class="phone">{{detail.addressSnapshot.receiverPhone}}</text>
    </view>
    <view class="addressText">{{detail.addressSnapshot.province}}{{detail.addressSnapshot.city}}{{detail.addressSnapshot.district}}{{detail.addressSnapshot.detailAddress}}</view>
  </view>

  <view class="sectionCard">
    <view class="sectionTitle">商品信息</view>
    <view wx:for="{{detail.items}}" wx:key="productId" class="goodsItem">
      <image class="goodsCover" src="{{item.cover}}" mode="aspectFill"></image>
      <view class="goodsBody">
        <view class="goodsTitle">{{item.title}}</view>
        <view class="goodsMeta">单价 {{item.unitPriceText}} x {{item.quantity}}</view>
      </view>
      <view class="goodsPrice">{{item.subtotalText}}</view>
    </view>
  </view>

  <view class="sectionCard">
    <view class="sectionTitle">金额明细</view>
    <view class="amountRow"><text>商品金额</text><text>{{detail.goodsAmountText}}</text></view>
    <view class="amountRow"><text>运费</text><text>{{detail.shippingFeeText}}</text></view>
    <view class="amountRow total"><text>实付金额</text><text>{{detail.payAmountText}}</text></view>
  </view>

  <view class="sectionCard" wx:if="{{detail.delivery && (detail.delivery.company || detail.delivery.trackingNo)}}">
    <view class="sectionTitle">物流信息</view>
    <view class="metaLine" wx:if="{{detail.delivery.company}}">物流公司：{{detail.delivery.company}}</view>
    <view class="metaLine" wx:if="{{detail.delivery.trackingNo}}">物流单号：{{detail.delivery.trackingNo}}</view>
  </view>

  <view class="bottomBar">
    <button class="actionBtn ghost" bindtap="goOrderList">查看商品订单</button>
    <button wx:if="{{detail.actions.canCancel}}" class="actionBtn ghost" bindtap="cancelOrder">取消订单</button>
    <button wx:if="{{detail.actions.canPay}}" class="actionBtn primary" bindtap="payOrder">立即支付</button>
    <button wx:if="{{detail.actions.canConfirmReceive}}" class="actionBtn primary" bindtap="confirmReceive">确认收货</button>
  </view>
</view>
