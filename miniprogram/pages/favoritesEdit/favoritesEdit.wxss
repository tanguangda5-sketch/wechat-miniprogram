.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f6faf4 0%, #edf5ea 18%, #f8fbf7 100%);
  padding: 0 0 160rpx;
  box-sizing: border-box;
}

.topSpacer {
  height: 0;
}

.navBar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 12rpx 24rpx 18rpx;
}

.backBtn {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.backArrow {
  width: 22rpx;
  height: 22rpx;
  border-left: 4rpx solid #1f1f1f;
  border-bottom: 4rpx solid #1f1f1f;
  transform: rotate(45deg);
}

.navTitle {
  font-size: 34rpx;
  color: #233123;
}

.navRightPlaceholder {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 64rpx;
  height: 64rpx;
}

.filterRow {
  display: flex;
  gap: 24rpx;
  padding: 10rpx 24rpx 18rpx;
  background: transparent;
}

.selector {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 32rpx;
  color: #233123;
}

.selectorTextActive {
  color: #57984a;
}

.selectorArrow {
  font-size: 20rpx;
  color: #4a4a4a;
}

.panelMask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.18);
  z-index: 10;
}

.panelCard {
  position: relative;
  z-index: 11;
  margin: 0 24rpx 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.08);
}

.optionGrid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 20rpx;
}

.optionItem {
  min-height: 88rpx;
  border-radius: 18rpx;
  background: #f3f5f8;
  color: #313131;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0 12rpx;
}

.optionItemActive {
  background: #edf5ea;
  color: #57984a;
}

.listWrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 20rpx 24rpx 0;
}

.editRow {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.selectWrap {
  width: 42rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.selectCircle {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  border: 3rpx solid #1f1f1f;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.selectCircleActive {
  border-color: #57984a;
  background: #57984a;
}

.selectCheck {
  width: 16rpx;
  height: 9rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(-45deg);
  margin-top: -2rpx;
}

.resultCard {
  flex: 1;
  display: flex;
  align-items: stretch;
  border-radius: 20rpx;
  overflow: hidden;
  background: #f7fbf5;
  box-shadow: 0 18rpx 36rpx rgba(28, 28, 28, 0.06);
}

.resultCard--activity,
.resultCard--scenic,
.resultCard--hotel,
.resultCard--knowledge {
  min-height: 276rpx;
}

.resultCard--product {
  min-height: 180rpx;
}

.resultImageWrap {
  position: relative;
  width: 180rpx;
  flex-shrink: 0;
}

.resultImage {
  width: 180rpx;
  display: block;
  background: #e9edf1;
}

.resultImage--activity,
.resultImage--scenic,
.resultImage--hotel,
.resultImage--knowledge {
  height: 276rpx;
}

.resultImage--product {
  height: 180rpx;
}

.badge {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 56rpx;
  height: 42rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(32, 32, 32, 0.72);
  color: #ffffff;
  font-size: 22rpx;
  z-index: 2;
}

.resultBody {
  flex: 1;
  min-width: 0;
  padding: 18rpx 20rpx;
  display: flex;
  flex-direction: column;
}

.resultTitle {
  color: #1f2a1f;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.tagRow {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.resultTag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #edf5ea;
  color: #426046;
  font-size: 22rpx;
}

.resultFooter {
  margin-top: auto;
  padding-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.resultSold {
  font-size: 22rpx;
  color: #8ea08b;
  text-align: right;
}

.resultPrice {
  flex-shrink: 0;
  color: #57984a;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 700;
}

.emptyWrap {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.emptyText {
  color: #7f8f7f;
  font-size: 28rpx;
}

.bottomBar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 18rpx 24rpx calc(env(safe-area-inset-bottom) + 18rpx);
  background: rgba(255, 255, 255, 0.98);
}

.selectAllWrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 120rpx;
}

.selectAllText {
  font-size: 34rpx;
  color: #426046;
}

.deleteBtn {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  background: #d8d8d8;
  color: #fff;
  font-size: 50rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.deleteBtnActive {
  background: #57984a;
}

.deleteCount {
  margin-left: 14rpx;
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #57984a;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
  box-sizing: border-box;
}
