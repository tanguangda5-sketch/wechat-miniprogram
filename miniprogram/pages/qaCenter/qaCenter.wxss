.page{
  min-height: 100vh;
  background: #f6faf4;
  padding: 24rpx;
  box-sizing: border-box;
}

.card{
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.title{
  font-size: 34rpx;
  font-weight: 700;
  color: #1a2230;
}

.desc{
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: #9098a4;
}

