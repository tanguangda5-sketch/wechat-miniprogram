<view class="page">
  <view class="topbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="icon-btn" bindtap="onMenuTap">≡</view>
    <view class="icon-btn" bindtap="onSearchTap">⌕</view>
    <view class="icon-btn" bindtap="onAddTap">＋</view>
  </view>

  <view class="storySection">
    <view class="storySectionTitle">好友/搭子新笔记</view>
    <scroll-view wx:if="{{storyList.length}}" class="story-scroll" scroll-x enable-flex show-scrollbar="{{false}}">
      <view
        wx:for="{{storyList}}"
        wx:key="id"
        class="story-item"
        data-kind="{{item.kind}}"
        data-entry-type="{{item.entryType}}"
        data-id="{{item.id}}"
        data-note-id="{{item.noteId}}"
        bindtap="openStory"
      >
        <view wx:if="{{item.avatarUrl}}" class="story-avatar image-avatar">
          <image class="story-avatar-image" src="{{item.avatarUrl}}" mode="aspectFill" />
        </view>
        <view wx:else class="story-avatar" style="background: {{item.avatarColor}};">
          <text>{{item.avatarText}}</text>
        </view>
        <view wx:if="{{item.unreadText}}" class="story-badge">{{item.unreadText}}</view>
        <view wx:if="{{item.noteTitle}}" class="story-dot"></view>
        <view class="story-title">{{item.title}}</view>
      </view>
    </scroll-view>
    <view wx:else class="storyEmpty">
      好友或搭子发布新笔记后，会显示在这里
    </view>
  </view>

  <view class="list">
    <view
      wx:for="{{homeRows}}"
      wx:key="id"
      class="row"
      data-kind="{{item.kind}}"
      data-entry-type="{{item.entryType}}"
      data-id="{{item.id}}"
      bindtap="openRow"
    >
      <view wx:if="{{item.avatarUrl}}" class="row-avatar row-avatar-image-wrap">
        <image class="row-avatar-image" src="{{item.avatarUrl}}" mode="aspectFill"></image>
      </view>
      <view wx:else class="row-avatar" style="background: {{item.avatarColor}};">{{item.avatarText}}</view>
      <view class="row-main">
        <view class="row-title">{{item.title}}</view>
        <view class="row-subtitle">{{item.subtitle || item.preview}}</view>
      </view>
      <view class="row-side">
        <view class="row-time">{{item.timeText}}</view>
        <view wx:if="{{item.unreadText}}" class="row-unread">{{item.unreadText}}</view>
      </view>
    </view>
  </view>
</view>
