.page { min-height: 100vh; background: #ffffff; }
.topbar { display: flex; align-items: center; justify-content: flex-start; gap: 16rpx; padding: 0 24rpx 12rpx; background: #ffffff; }
.icon-btn { width: 86rpx; height: 86rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 48rpx; color: #1f1f1f; }
.story-scroll { white-space: nowrap; padding: 8rpx 18rpx 20rpx; box-sizing: border-box; border-bottom: 1rpx solid #f1f1f1; }
.story-item { width: 132rpx; display: inline-flex; flex-direction: column; align-items: center; margin: 0 10rpx; vertical-align: top; position: relative; }
.story-avatar { position: relative; width: 108rpx; height: 108rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #ffffff; font-size: 40rpx; font-weight: 700; box-shadow: 0 10rpx 22rpx rgba(0, 0, 0, 0.08); }
.image-avatar { overflow: visible; background: #f2f2f2; box-shadow: none; }
.story-avatar-image { width: 108rpx; height: 108rpx; border-radius: 50%; display: block; }
.story-plus { position: absolute; right: -4rpx; bottom: -2rpx; width: 34rpx; height: 34rpx; border-radius: 50%; background: #42c35c; color: #fff; font-size: 28rpx; line-height: 34rpx; text-align: center; border: 4rpx solid #fff; }
.story-badge { position: absolute; top: -4rpx; right: 10rpx; min-width: 26rpx; height: 26rpx; padding: 0 6rpx; border-radius: 999rpx; background: #ff3b68; color: #ffffff; font-size: 16rpx; line-height: 26rpx; text-align: center; box-sizing: border-box; }
.story-dot { margin-top: 10rpx; width: 10rpx; height: 10rpx; border-radius: 50%; background: #ff4f8a; }
.story-title { width: 100%; margin-top: 10rpx; text-align: center; font-size: 22rpx; color: #222222; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.list { background: #ffffff; }
.row { position: relative; display: flex; align-items: center; padding: 24rpx; border-bottom: 1rpx solid #f5f5f5; }
.row-avatar { width: 94rpx; height: 94rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: #ffffff; font-size: 34rpx; font-weight: 700; }
.row-main { flex: 1; min-width: 0; margin-left: 20rpx; padding-right: 18rpx; }
.row-title { font-size: 30rpx; font-weight: 400; color: #111111; }
.row-side { width: 72rpx; display: flex; flex-direction: column; align-items: flex-end; justify-content: center; flex-shrink: 0; }
.row-time { font-size: 24rpx; color: #b3b3b3; line-height: 1; }
.row-subtitle { margin-top: 10rpx; font-size: 28rpx; color: #868686; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.row-unread { min-width: 34rpx; height: 34rpx; margin-top: 14rpx; padding: 0 8rpx; border-radius: 999rpx; background: #ff3b68; color: #ffffff; font-size: 20rpx; line-height: 34rpx; text-align: center; box-sizing: border-box; }
