.page {
  min-height: 100vh;
  background: #f6faf4;
  padding: 0 24rpx 24rpx;
  box-sizing: border-box;
}

.tabBarWrap {
  position: sticky;
  top: 0;
  z-index: 20;
  background: #f6faf4;
  padding: 20rpx 0 18rpx;
}

.tagScroll {
  width: 100%;
}

.tagRow {
  display: inline-flex;
  gap: 16rpx;
}

.filterTag {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: #edf5ea;
  color: #5f7260;
  font-size: 28rpx;
  white-space: nowrap;
}

.filterTag.active {
  background: #57984a;
  color: #ffffff;
}

.cardList {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-top: 6rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.cardCover {
  width: 100%;
  height: 320rpx;
  display: block;
}

.cardBody {
  padding: 20rpx 22rpx 24rpx;
}

.cardTitle {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2a1f;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.cardTags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #edf5ea;
  color: #5f7260;
  font-size: 24rpx;
}

.emptyState {
  padding: 56rpx 24rpx;
  text-align: center;
  color: #7a8d79;
  font-size: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
}
