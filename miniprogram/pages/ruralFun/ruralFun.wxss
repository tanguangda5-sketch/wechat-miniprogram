.page {
  min-height: 100vh;
  background: #f6faf4;
  padding: 24rpx;
  box-sizing: border-box;
}

.hero {
  background: linear-gradient(135deg, #edf6e9 0%, #e2f0df 100%);
  border-radius: 28rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
}

.heroTitle {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #234028;
  margin-bottom: 12rpx;
}

.heroDesc {
  display: block;
  font-size: 26rpx;
  line-height: 1.7;
  color: #5b725b;
}

.tagScroll {
  width: 100%;
  margin-bottom: 24rpx;
}

.tagRow {
  display: inline-flex;
  gap: 16rpx;
}

.filterTag {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: #edf5ea;
  color: #5f7260;
  font-size: 28rpx;
  white-space: nowrap;
}

.filterTag.active {
  background: #57984a;
  color: #ffffff;
}

.cardList {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.cardCover {
  width: 100%;
  height: 320rpx;
  display: block;
}

.cardBody {
  padding: 20rpx 22rpx 24rpx;
}

.cardTitle {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2a1f;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.cardTags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #edf5ea;
  color: #5f7260;
  font-size: 24rpx;
}


