<view class="page">
  <view class="tabBarWrap">
    <scroll-view class="tagScroll" scroll-x="{{true}}" enable-flex="{{true}}" show-scrollbar="{{false}}">
      <view class="tagRow">
        <view
          wx:for="{{tagGroups}}"
          wx:key="id"
          class="filterTag {{activeTagIndex===index ? 'active' : ''}}"
          data-idx="{{index}}"
          bindtap="changeTag"
        >
          {{item.title}}
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="cardList">
    <view
      wx:for="{{showList}}"
      wx:key="id"
      class="card"
      data-id="{{item.id}}"
      bindtap="goActivityDetail"
    >
      <image src="{{item.cover}}" class="cardCover" mode="aspectFill" />
      <view class="cardBody">
        <text class="cardTitle">{{item.title}}</text>
        <view class="cardTags">
          <text wx:for="{{item.tags}}" wx:key="*this" class="tag">{{item}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{!showList.length}}" class="emptyState">
      当前分类下暂无活动
    </view>
  </view>
</view>
