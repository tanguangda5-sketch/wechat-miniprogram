.page {
  min-height: 100vh;
  padding: 120rpx 32rpx 32rpx;
  background: linear-gradient(180deg, #f6efe2 0%, #eef6ea 100%);
  box-sizing: border-box;
}

.card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(54, 79, 57, 0.08);
}

.title {
  font-size: 38rpx;
  color: #234028;
  font-weight: 600;
}

.desc {
  margin-top: 20rpx;
  font-size: 27rpx;
  line-height: 1.8;
  color: #6f7f6e;
}

.status {
  margin-top: 20rpx;
  color: #57984a;
  font-size: 26rpx;
}

.primary,
.secondary {
  margin-top: 28rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  border: none;
  font-size: 30rpx;
}

.primary {
  background: #57984a;
  color: #ffffff;
}

.secondary {
  background: #eef4ea;
  color: #567055;
}

