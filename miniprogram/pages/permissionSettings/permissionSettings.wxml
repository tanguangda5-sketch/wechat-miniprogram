<view class="page">
  <view class="card">
    <view class="title">{{text.title}}</view>
    <view class="desc">{{text.desc}}</view>

    <view class="status" wx:if="{{locationAuthorized}}">
      {{text.statusOn}}
    </view>

    <button class="primary" bindtap="onAuthorizeLocation" loading="{{loading}}" disabled="{{loading}}">
      {{text.authorize}}
    </button>
    <button class="secondary" bindtap="onSkipLocation" disabled="{{loading}}">
      {{mode === 'settings' ? text.keepSettings : text.skip}}
    </button>
  </view>
</view>