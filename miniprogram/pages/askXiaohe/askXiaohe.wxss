.page {
  min-height: 100vh;
  padding: 26rpx 24rpx;
  background: linear-gradient(180deg, #fbf5ff 0%, #ffffff 34%, #fafafc 100%);
  box-sizing: border-box;
}

.topbar {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.backBtn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #1f1f1f;
  background: rgba(255, 255, 255, 0.8);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #232323;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8c8c8c;
}

.card {
  margin-top: 32rpx;
  padding: 36rpx 32rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 20rpx 40rpx rgba(114, 90, 151, 0.08);
}

.cardTitle {
  font-size: 34rpx;
  font-weight: 700;
  color: #262626;
}

.cardDesc {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #6e6e6e;
}

.cardAction {
  display: inline-flex;
  margin-top: 28rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #8aaeff 0%, #b27cff 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}
