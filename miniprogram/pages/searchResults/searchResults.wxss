.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f6faf4 0%, #edf5ea 18%, #f8fbf7 100%);
}

.fixedTop {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 12rpx;
  background: linear-gradient(180deg, #f6faf4 0%, #edf5ea 18%, #f8fbf7 100%);
}

.topbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 72rpx;
  padding: 10rpx 0 12rpx;
}

.backBtn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.backArrow {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #1f1f1f;
  border-bottom: 4rpx solid #1f1f1f;
  transform: rotate(45deg);
}

.searchBar {
  width: calc(100% - 300rpx);
  max-width: 500rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 64rpx;
  padding: 4rpx 6rpx 4rpx 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 4rpx solid #d7e8d3;
  box-shadow: 0 16rpx 32rpx rgba(87, 152, 74, 0.08);
}

.searchInput {
  flex: 1;
  min-width: 0;
  font-size: 27rpx;
  color: #1f1f1f;
}

.searchPlaceholder {
  color: #b3b3b3;
}

.searchBtn {
  flex-shrink: 0;
  min-width: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  text-align: center;
  background: linear-gradient(90deg, #57984a 0%, #57984a 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
}

.resultTabs {
  white-space: nowrap;
  padding: 4rpx 0 0;
}

.resultTab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-right: 40rpx;
  padding: 10rpx 0 12rpx;
  color: #7f8f7f;
  font-size: 31rpx;
  font-weight: 600;
}

.resultTab.active {
  color: #233123;
}

.resultTab.active::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 4rpx;
  border-radius: 999rpx;
  background: #57984a;
}

.content {
  padding: 300rpx 24rpx 40rpx;
}

.resultList {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.resultCard {
  display: flex;
  align-items: stretch;
  border-radius: 20rpx;
  overflow: hidden;
  background: #f7fbf5;
  box-shadow: 0 18rpx 36rpx rgba(28, 28, 28, 0.06);
}

.resultCard--activity,
.resultCard--scenic,
.resultCard--hotel {
  min-height: 276rpx;
}

.resultCard--product {
  min-height: 180rpx;
}

.resultImage {
  width: 180rpx;
  flex-shrink: 0;
  display: block;
}

.resultImageWrap {
  position: relative;
  width: 180rpx;
  flex-shrink: 0;
}

.resultImage--activity,
.resultImage--scenic,
.resultImage--hotel {
  height: 276rpx;
}

.resultImage--product {
  height: 180rpx;
}

.resultBody {
  flex: 1;
  min-width: 0;
  padding: 18rpx 20rpx;
  display: flex;
  flex-direction: column;
}

.resultTitleRow {
  display: flex;
  align-items: flex-start;
}

.resultTitle {
  flex: 1;
  min-width: 0;
  color: #1f2a1f;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.resultType {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 56rpx;
  height: 42rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(32, 32, 32, 0.72);
  color: #ffffff;
  font-size: 22rpx;
  z-index: 2;
}

.tagRow {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.resultTag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #edf5ea;
  color: #426046;
  font-size: 22rpx;
}

.resultFooter {
  margin-top: auto;
  padding-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.resultPrice {
  flex-shrink: 0;
  color: #57984a;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 700;
}

.resultSold {
  font-size: 22rpx;
  color: #8ea08b;
  text-align: right;
}

.emptyBlock {
  padding: 80rpx 36rpx;
  text-align: center;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #909090;
  font-size: 28rpx;
}
