.page { min-height:100vh; background:linear-gradient(180deg,#fff7f7 0%,#f7f8ff 100%); padding:24rpx; box-sizing:border-box; }
.card { margin-bottom:24rpx; padding:28rpx; border-radius:28rpx; background:#fff; box-shadow:0 14rpx 34rpx rgba(0,0,0,0.05); }
.time { text-align:center; font-size:24rpx; color:#9c9c9c; margin-bottom:20rpx; }
.title { font-size:34rpx; font-weight:700; color:#3b3b3b; }
.subtitle { margin-top:18rpx; font-size:30rpx; color:#222; font-weight:700; }
.content { margin-top:16rpx; font-size:27rpx; line-height:1.7; color:#5b5b5b; }
.order-card { margin-top:20rpx; padding:22rpx; border-radius:20rpx; background:#f7f7f9; }
.order-title { font-size:30rpx; color:#222; font-weight:700; }
.order-no { margin-top:10rpx; font-size:24rpx; color:#787878; }
.action { margin-top:24rpx; height:84rpx; border-radius:22rpx; background:#ff3b68; color:#fff; font-size:30rpx; font-weight:700; line-height:84rpx; text-align:center; }
