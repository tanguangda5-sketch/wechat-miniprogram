.page { min-height:100vh; background:#fff; padding:28rpx 24rpx; box-sizing:border-box; }
.header { font-size:40rpx; font-weight:700; color:#111; margin-bottom:24rpx; }
.card { padding:32rpx 28rpx; border-radius:28rpx; color:#fff; margin-bottom:18rpx; }
.support { background:linear-gradient(135deg,#44b96f,#2e8b57); }
.guarantee { background:linear-gradient(135deg,#ff7f8d,#ff4972); }
.card-title { font-size:34rpx; font-weight:700; }
.card-desc { margin-top:14rpx; font-size:26rpx; line-height:1.7; opacity:0.95; }
