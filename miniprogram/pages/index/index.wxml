<view class="page">
  <view class="title">活动列表</view>

  <view wx:if="{{loading}}" class="tip">加载中...</view>

  <view wx:elif="{{list.length === 0}}" class="tip">暂无活动</view>

  <view wx:else>
    <view wx:for="{{list}}" wx:key="_id" class="card"
      data-id="{{item._id}}" bindtap="cardTap">
      <view class="card-title">{{item.title}}</view>
      <view class="card-content">{{item.content}}</view>
      <view class="card-time">{{item.createdAt}}</view>
    </view>
  </view>

  <button class="btn" bindtap="loadList">刷新</button>
</view>
