.page {
  padding: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.tip {
  color: #99a598;
  padding: 40rpx 0;
  text-align: center;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 18rpx rgba(0,0,0,0.06);
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.card-content {
  font-size: 28rpx;
  color: #233123;
  margin-bottom: 12rpx;
}

.card-time {
  font-size: 24rpx;
  color: #99a598;
}

.btn {
  margin-top: 20rpx;
}

