.page {
  min-height: 100vh;
  background: #f6faf4;
  padding-bottom: 30rpx;
}

.topSpacer {
  height: 72rpx;
}

.header {
  padding: 0 24rpx 20rpx;
}

.dnaTagsBox {
  margin: 12rpx 24rpx 18rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx;
}

.dnaTagsLabel {
  font-size: 30rpx;
  color: #1f2a1f;
  margin-bottom: 12rpx;
  font-weight: 400;
}

.dnaTags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.dnaPlaceholder {
  font-size: 24rpx;
  color: #8ea08b;
  line-height: 1.6;
}

.buddyIntentSummary {
  font-size: 24rpx;
  color: #426046;
  line-height: 1.7;
}

.tag {
  background: #edf5ea;
  border: 1rpx solid #57984a;
  color: #57984a;
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.userBox {
  display: flex;
  align-items: center;
}

.userBoxLoggedIn {
  padding: 18rpx 8rpx 6rpx 8rpx;
}

.userBoxGuest {
  padding: 18rpx 8rpx 6rpx 8rpx;
}

.avatar {
  width: 124rpx;
  height: 124rpx;
  border-radius: 999rpx;
  background: #e5efe1;
  flex-shrink: 0;
}

.userInfo {
  margin-left: 22rpx;
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2a1f;
}

.edit {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #99a598;
}

.guestRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.guestHint {
  flex: 1;
  font-size: 27rpx;
  font-weight: 500;
  color: #1f2a1f;
  line-height: 1.45;
}

.loginButton {
  flex-shrink: 0;
  min-width: 120rpx;
  height: 62rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: #57984a;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 18rpx rgba(87, 152, 74, 0.18);
}

.orderSection {
  margin: 12rpx 24rpx 18rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx 18rpx;
}

.orderHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.orderTitle {
  font-size: 30rpx;
  font-weight: 400;
  color: #1f2a1f;
}

.orderAll {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #8ea08b;
}

.orderAllArrow {
  margin-left: 8rpx;
  font-size: 30rpx;
}

.orderIcons {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8rpx;
}

.productOrderEntry {
  margin-top: 28rpx;
  padding: 22rpx 20rpx;
  border-radius: 18rpx;
  background: #f6faf4;
  border: 1rpx solid #e3ece0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.productOrderBody {
  min-width: 0;
  flex: 1;
}

.productOrderTitle {
  font-size: 28rpx;
  color: #1f2a1f;
  font-weight: 600;
}

.productOrderDesc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8ea08b;
  line-height: 1.5;
}

.orderItem {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.orderIcon {
  width: 58rpx;
  height: 58rpx;
}

.orderLabel {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.4;
  color: #1f2a1f;
  text-align: center;
}

.menu {
  margin: 0 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
}

.menuItem {
  padding: 26rpx 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #e3ece0;
}

.menuItem:last-child {
  border-bottom: none;
}

.menuText {
  font-size: 28rpx;
  color: #1f2a1f;
}

.arrow {
  font-size: 34rpx;
  color: #bbb;
  margin-left: 12rpx;
}

.logout .menuText {
  color: #d9544f;
}
