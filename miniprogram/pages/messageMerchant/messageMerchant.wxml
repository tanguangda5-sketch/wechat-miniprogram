<view class="page">
  <view class="header">商家消息</view>
  <view wx:for="{{list}}" wx:key="id" class="row" data-id="{{item.id}}" bindtap="openChat">
    <view class="avatar" style="background: {{item.avatarColor}};">{{item.avatarText}}</view>
    <view class="main">
      <view class="line">
        <view class="title">{{item.shopName}}</view>
        <view class="time">{{item.timeText}}</view>
      </view>
      <view class="preview">{{item.preview}}</view>
    </view>
    <view wx:if="{{item.unreadText}}" class="badge">{{item.unreadText}}</view>
  </view>
</view>
