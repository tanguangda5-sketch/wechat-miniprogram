.page { min-height:100vh; background:#fff; }
.header { padding:28rpx 24rpx; font-size:40rpx; font-weight:700; color:#111; }
.row { display:flex; align-items:center; padding:24rpx; border-top:1rpx solid #f5f5f5; }
.avatar { width:88rpx; height:88rpx; border-radius:28rpx; display:flex; align-items:center; justify-content:center; color:#fff; font-size:32rpx; font-weight:700; flex-shrink:0; }
.main { flex:1; margin-left:20rpx; min-width:0; }
.line { display:flex; justify-content:space-between; gap:16rpx; }
.title { font-size:32rpx; font-weight:700; color:#111; }
.time { font-size:24rpx; color:#a0a0a0; }
.preview { margin-top:10rpx; font-size:26rpx; color:#767676; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.badge { min-width:38rpx; height:38rpx; padding:0 10rpx; border-radius:999rpx; background:#ff3b68; color:#fff; font-size:22rpx; line-height:38rpx; text-align:center; box-sizing:border-box; }
