.page {
  min-height: 100vh;
  background: #f6faf4;
  padding-bottom: 30rpx;
}

.customNav {
  background: #f6faf4;
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 14rpx;
}

.navCapsuleRow {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.locationInfo {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #1f2a1f;
  max-width: 70%;
}

.locationIcon {
  width: 24rpx;
  height: 24rpx;
  border: 4rpx solid #1f2a1f;
  border-radius: 50%;
  position: relative;
}

.locationIcon::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: -12rpx;
  width: 4rpx;
  height: 14rpx;
  background: #1f2a1f;
  transform: translateX(-50%);
  border-radius: 999rpx;
}

.locationText {
  font-size: 30rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.locationArrow {
  font-size: 24rpx;
  flex-shrink: 0;
}

.capsuleSpacer {
  width: 180rpx;
  height: 64rpx;
}

.searchRow {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 6rpx;
}

.searchBox {
  flex: 1;
  min-height: 82rpx;
  padding: 0 10rpx 0 0;
  border-radius: 999rpx;
  background: #ffffff;
  border: 3rpx solid #d7e8d3;
  display: flex;
  align-items: center;
  box-shadow: 0 14rpx 28rpx rgba(54, 102, 61, 0.08);
}

.searchInputArea {
  flex: 1;
  min-width: 0;
  min-height: 82rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx 0 26rpx;
}

.searchInputText {
  color: #8ea08b;
  font-size: 26rpx;
  font-weight: 400;
}

.searchAction {
  flex-shrink: 0;
  min-width: 96rpx;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #57984a;
  color: #ffffff;
  font-size: 26rpx;
  text-align: center;
  font-weight: 400;
}

.scanAction {
  width: 82rpx;
  height: 82rpx;
  border-radius: 22rpx;
  background: #edf5ea;
  box-shadow: 0 14rpx 28rpx rgba(54, 102, 61, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.scanIcon {
  width: 40rpx;
  height: 40rpx;
  position: relative;
  border-left: 4rpx solid transparent;
}

.scanIcon::before,
.scanIcon::after {
  content: '';
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  border: 4rpx solid #1f2a1f;
}

.scanIcon::before {
  left: 0;
  top: 0;
  border-right: none;
  border-bottom: none;
}

.scanIcon::after {
  right: 0;
  bottom: 0;
  border-left: none;
  border-top: none;
}

.nav {
  margin: 18rpx 24rpx 24rpx;
  background: #ffffff;
  border-radius: 22rpx;
  padding: 26rpx 6rpx;
  display: flex;
  justify-content: space-between;
  box-shadow: 0 16rpx 32rpx rgba(53, 88, 57, 0.06);
}

.navItem {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.navIconImg {
  width: 88rpx;
  height: 88rpx;
  display: block;
}

.navText {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #41513f;
  text-align: center;
}

.bannerWrap {
  margin: 0 24rpx 24rpx;
}

.bannerSwiper {
  width: 100%;
  height: 360rpx;
}

.bannerItem {
  width: 100%;
  height: 100%;
  border-radius: 28rpx;
  overflow: hidden;
}

.bannerImg {
  width: 100%;
  height: 100%;
  display: block;
}

.themeSection {
  margin: 0 24rpx;
}

.sectionHead {
  margin-bottom: 18rpx;
}

.hotTitle {
  display: flex;
  align-items: center;
}

.line {
  width: 8rpx;
  height: 34rpx;
  background: #57984a;
  border-radius: 999rpx;
  margin-right: 12rpx;
}

.titleText {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2a1f;
}

.themeTabsScroll {
  width: 100%;
  margin-bottom: 12rpx;
}

.hotTabs {
  display: inline-flex;
  gap: 16rpx;
  padding-bottom: 2rpx;
}

.tab {
  padding: 10rpx 22rpx;
  border-radius: 22rpx;
  background: #eef6ee;
  color: #5f7260;
  font-size: 28rpx;
  white-space: nowrap;
}

.tab.active {
  background: #57984a;
  color: #ffffff;
}

.themePanel {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
}

.themePanelHead {
  margin-bottom: 28rpx;
}

.themeTitleRow {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 12rpx;
}

.themePeriod {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #edf5ea;
  color: #5f7260;
  font-size: 22rpx;
}

.themeDesc {
  font-size: 26rpx;
  color: #667566;
  line-height: 1.7;
}

.themeBlock {
  margin-bottom: 26rpx;
}

.themeBlock:last-child {
  margin-bottom: 0;
}

.themeBlockTitle {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #233123;
  margin-bottom: 18rpx;
}

.themeActivityCard {
  display: flex;
  align-items: stretch;
  background: #f7fbf5;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 18rpx;
  height: 276rpx;
}

.themeActivityCard:last-child {
  margin-bottom: 0;
}

.themeActivityCoverWrap {
  width: 180rpx;
  height: 276rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.themeActivityCover {
  width: 100%;
  height: 100%;
  flex-shrink: 0;
  display: block;
}

.themeActivityBody {
  flex: 1;
  min-width: 0;
  padding: 18rpx 20rpx;
  display: flex;
  flex-direction: column;
}

.themeActivityName {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2a1f;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.themeActivityMeta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.dayTag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #57984a;
  color: #ffffff;
  font-size: 22rpx;
}

.themeActivityFooter {
  margin-top: auto;
  padding-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.themeActivityPrice {
  font-size: 30rpx;
  line-height: 1;
  color: #57984a;
  font-weight: 700;
}

.themeActivitySold {
  font-size: 22rpx;
  color: #8ea08b;
  text-align: right;
}

.themeProductList {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.themeProductCard {
  display: flex;
  align-items: stretch;
  background: #f7fbf5;
  border-radius: 20rpx;
  overflow: hidden;
  height: 180rpx;
}

.themeProductCover {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
}

.themeProductBody {
  flex: 1;
  min-width: 0;
  padding: 18rpx 20rpx;
  display: flex;
  flex-direction: column;
}

.themeProductName {
  font-size: 28rpx;
  line-height: 1.5;
  color: #1f2a1f;
  font-weight: 600;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.themeProductTags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.productTag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #edf5ea;
  color: #426046;
  font-size: 22rpx;
}

.themeProductFooter {
  margin-top: auto;
  padding-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.themeProductPrice {
  font-size: 30rpx;
  line-height: 1;
  color: #57984a;
  font-weight: 700;
}

.themeProductSold {
  font-size: 22rpx;
  color: #8ea08b;
  text-align: right;
}

.emptyState {
  padding: 28rpx 0;
  font-size: 26rpx;
  color: #8ea08b;
}

.publishFloat {
  position: fixed;
  right: 28rpx;
  bottom: 120rpx;
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5ea94f 0%, #3f8a3e 100%);
  box-shadow: 0 18rpx 36rpx rgba(63, 138, 62, 0.28);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  z-index: 20;
}

.publishFloatPlus {
  font-size: 48rpx;
  line-height: 1;
  font-weight: 600;
}

.publishFloatText {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.2;
}


