.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f6faf4 0%, #edf5ea 18%, #f8fbf7 100%);
  padding: 0 24rpx 48rpx;
  box-sizing: border-box;
}

.topSpacer {
  height: 0;
}

.navBar {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 88rpx;
  padding: 12rpx 0 18rpx;
}

.backBtn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.backArrow {
  width: 22rpx;
  height: 22rpx;
  border-left: 4rpx solid #1f1f1f;
  border-bottom: 4rpx solid #1f1f1f;
  transform: rotate(45deg);
}

.navTabs {
  display: flex;
  align-items: center;
  gap: 44rpx;
  flex-shrink: 0;
}

.navTab {
  position: relative;
  padding: 8rpx 0 12rpx;
  font-size: 34rpx;
  color: #9a9a9a;
  font-weight: 400;
}

.navTabActive {
  color: #233123;
  font-weight: 400;
}

.navTabActive::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 58rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #57984a;
  transform: translateX(-50%);
}

.navAction {
  margin-left: 10rpx;
  min-width: 56rpx;
  text-align: left;
  font-size: 24rpx;
  color: #57984a;
  flex-shrink: 0;
}

.navSpacer {
  flex: 1;
}

.filterRow {
  display: flex;
  gap: 24rpx;
  padding: 10rpx 4rpx 18rpx;
  background: transparent;
}

.selector {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 32rpx;
  color: #1f2a1f;
}

.selectorText {
  color: #1f2a1f;
}

.selectorTextActive {
  color: #57984a;
}

.selectorArrow {
  font-size: 20rpx;
  color: #4a4a4a;
}

.panelMask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.18);
  z-index: 10;
}

.panelCard {
  position: relative;
  z-index: 11;
  margin-bottom: 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.08);
}

.optionGrid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 20rpx;
}

.optionItem {
  min-height: 88rpx;
  border-radius: 18rpx;
  background: #f3f5f8;
  color: #313131;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0 12rpx;
}

.optionItemActive {
  background: #edf5ea;
  color: #57984a;
}

.listWrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.groupTitle {
  margin-top: 8rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #233123;
}

.resultCard {
  display: flex;
  align-items: stretch;
  border-radius: 20rpx;
  overflow: hidden;
  background: #f7fbf5;
  box-shadow: 0 18rpx 36rpx rgba(28, 28, 28, 0.06);
}

.resultCard--activity,
.resultCard--scenic,
.resultCard--hotel,
.resultCard--knowledge {
  min-height: 276rpx;
}

.resultCard--product {
  min-height: 180rpx;
}

.resultImageWrap {
  position: relative;
  width: 180rpx;
  flex-shrink: 0;
}

.resultImage {
  width: 180rpx;
  display: block;
  background: #e9edf1;
}

.resultImage--activity,
.resultImage--scenic,
.resultImage--hotel,
.resultImage--knowledge {
  height: 276rpx;
}

.resultImage--product {
  height: 180rpx;
}

.badge {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 56rpx;
  height: 42rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(32, 32, 32, 0.72);
  color: #ffffff;
  font-size: 22rpx;
  z-index: 2;
}

.resultBody {
  flex: 1;
  min-width: 0;
  padding: 18rpx 20rpx;
  display: flex;
  flex-direction: column;
}

.resultTitle {
  color: #1f2a1f;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.tagRow {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.resultTag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #edf5ea;
  color: #426046;
  font-size: 22rpx;
}

.resultFooter {
  margin-top: auto;
  padding-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.resultPrice {
  flex-shrink: 0;
  color: #57984a;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 700;
}

.resultSold {
  font-size: 22rpx;
  color: #8ea08b;
  text-align: right;
}

.emptyWrap {
  display: flex;
  min-height: 72vh;
  padding: 0 48rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.emptyIcon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 30rpx;
  background: linear-gradient(180deg, #eef5ea 0%, #e5efe1 100%);
}

.emptyTitle {
  margin-top: 28rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2a1f;
}

.emptyDesc {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #99a598;
}
