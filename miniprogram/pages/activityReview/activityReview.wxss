.page{
  min-height:100vh;
  background:#f6faf4;
  padding:24rpx;
}

.card{
  background:#ffffff;
  border-radius:18rpx;
  padding:24rpx;
}

.title{
  font-size:32rpx;
  font-weight:700;
  margin-bottom:20rpx;
}

.label{
  margin-top:20rpx;
  margin-bottom:10rpx;
  color:#233123;
}

.stars{
  display:flex;
}

.star{
  font-size:52rpx;
  color:#c5d8c0;
  margin-right:10rpx;
}

.star.on{
  color:#ffb400;
}

.textarea{
  border:1rpx solid #dbe8d7;
  border-radius:12rpx;
  padding:20rpx;
  min-height:220rpx;
}

.submit{
  margin-top:30rpx;
  background:#57984a;
  color:#ffffff;
}
