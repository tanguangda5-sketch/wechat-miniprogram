.page{
  min-height:100vh;
  background:#f6faf4;
  padding:24rpx;
  padding-bottom:140rpx;
}

.card{
  background:#ffffff;
  border-radius:18rpx;
  padding:24rpx;
  margin-bottom:20rpx;
}

.title{
  font-size:34rpx;
  font-weight:700;
  margin-bottom:16rpx;
  color:#1f2a1f;
}

.sectionTitle{
  font-size:30rpx;
  font-weight:700;
  margin-bottom:14rpx;
  color:#1f2a1f;
}

.row{
  display:flex;
  margin:12rpx 0;
}

.label{
  width:150rpx;
  color:#667566;
}

.status.pending_payment{ color:#57984a; }
.status.upcoming{ color:#57984a; }
.status.pending_review{ color:#57984a; }
.status.refunding{ color:#57984a; }
.status.cancelled{ color:#99a598; }
.status.completed{ color:#57984a; }

.price{
  font-size:36rpx;
  font-weight:700;
}

.countdown{
  margin-top:18rpx;
  color:#57984a;
  font-size:28rpx;
  font-weight:600;
}

.refundBox{
  margin-top:16rpx;
  color:#57984a;
  font-size:26rpx;
  line-height:1.6;
}

.traveler{
  padding:16rpx 0;
  border-bottom:1rpx solid #e3ece0;
}

.traveler:last-child{
  border-bottom:none;
}

.travSub{
  color:#667566;
  margin-top:6rpx;
  font-size:24rpx;
}

.bottomBar{
  position:fixed;
  left:0;
  right:0;
  bottom:0;
  background:#ffffff;
  padding:18rpx 24rpx;
  display:flex;
  justify-content:flex-end;
  flex-wrap:wrap;
  gap:14rpx;
  box-shadow:0 -2rpx 18rpx rgba(0,0,0,0.08);
}

.actionBtn{
  border-radius:999rpx;
  font-size:26rpx;
}

.actionBtn.gray{
  background:#edf5ea;
  color:#233123;
}

.actionBtn.primary{
  background:#57984a;
  color:#ffffff;
}
