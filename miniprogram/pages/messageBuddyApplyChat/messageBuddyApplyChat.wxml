<view class="page">
  <view class="notice">只要你发送任意一条消息，这条搭子申请就会转入主页正式会话。</view>
  <view class="chat-list">
    <view wx:for="{{messages}}" wx:key="id" class="msg theirs">
      <view class="bubble">
        <view>{{item.text}}</view>
        <view class="time">{{item.timeText}}</view>
      </view>
    </view>
  </view>
  <view class="composer">
    <input class="input" placeholder="回复后转入正式会话..." value="{{inputValue}}" bindinput="onInput" />
    <view class="send" bindtap="sendMessage">发送</view>
  </view>
</view>
