<view class="page container-safe">
  <view class="hero">
    <image
      wx:if="{{heroCover}}"
      class="hero-bg"
      src="{{heroCover}}"
      mode="aspectFill"
    ></image>
    <view class="hero-bg hero-placeholder" wx:else></view>
    <view class="hero-mask"></view>
    <view class="hero-content">
      <view class="hero-chip">{{heroChip}}</view>
      <view class="hero-title">{{heroTitle}}</view>
      <view class="hero-subtitle">{{heroSubtitle}}</view>
      <view class="hero-desc">{{heroDesc}}</view>
    </view>
  </view>

  <view class="sheet">
    <view class="tab-row">
      <view class="tab {{activeTab === 'agri' ? 'active' : ''}}" data-tab="agri" bindtap="switchTab">农事宝典</view>
      <view class="tab {{activeTab === 'culture' ? 'active' : ''}}" data-tab="culture" bindtap="switchTab">文旅课堂</view>
      <view class="tab {{activeTab === 'red' ? 'active' : ''}}" data-tab="red" bindtap="switchTab">红色文旅</view>
    </view>

    <scroll-view class="category-scroll" scroll-x enable-flex show-scrollbar="false">
      <view class="category-list">
        <block wx:for="{{categories}}" wx:key="index">
          <view
            class="category-chip {{currentCategory === item ? 'selected' : ''}}"
            data-category="{{item}}"
            bindtap="switchCategory"
          >
            {{item}}
          </view>
        </block>
      </view>
    </scroll-view>

    <view class="feed-head">
      <view>
        <view class="feed-title">{{feedTitle}}</view>
        <view class="feed-subtitle">{{feedSubtitle}}</view>
      </view>
      <view class="feed-count">{{filteredList.length}} 篇内容</view>
    </view>

    <view class="loading-box" wx:if="{{loading}}">正在加载文章...</view>

    <block wx:elif="{{filteredList.length}}">
      <block wx:for="{{filteredList}}" wx:key="id">
        <view class="news-card" data-id="{{item.id}}" bindtap="goDetail">
          <view class="news-main">
            <view class="news-left">
              <view class="news-title">{{item.title}}</view>
              <view class="news-author">{{item.author}}</view>
              <view class="news-time">{{item.publishTime}}</view>
              <view class="news-tag-row">
                <block wx:for="{{item.tags}}" wx:key="index" wx:for-item="tag">
                  <text class="news-tag">{{tag}}</text>
                </block>
              </view>
            </view>
            <view class="news-right">
              <image class="cover" src="{{item.cover}}" mode="aspectFill"></image>
              <view class="cover-views">{{item.views}}</view>
            </view>
          </view>
          <view class="news-meta-row">
            <view class="news-wordcount">{{item.wordCount}}字</view>
            <view class="footer-right">
              <text class="stat-item">赞 {{item.likes}}</text>
              <text class="stat-item">评 {{item.comments}}</text>
              <text class="stat-item">转 {{item.shareCount}}</text>
            </view>
          </view>
        </view>
      </block>
    </block>

    <view class="empty-box" wx:else>
      <view class="empty-title">{{emptyTitle}}</view>
      <view class="empty-text">{{emptyText}}</view>
    </view>
  </view>
</view>
