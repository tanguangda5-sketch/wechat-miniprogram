.page {
  min-height: 100vh;
  background: #f6faf4;
  padding: 24rpx 24rpx 140rpx;
  box-sizing: border-box;
}

.formCard {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 12rpx 30rpx rgba(55, 42, 26, 0.06);
}

.field + .field,
.switchRow {
  margin-top: 24rpx;
}

.label {
  font-size: 26rpx;
  color: #667566;
}

.input,
.textarea {
  width: 100%;
  margin-top: 12rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: #f4f7f2;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #1f2a1f;
}

.textarea {
  min-height: 180rpx;
}

.switchRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.saveBtn {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(env(safe-area-inset-bottom) + 20rpx);
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  background: #57984a;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.saveBtn::after {
  border: none;
}
