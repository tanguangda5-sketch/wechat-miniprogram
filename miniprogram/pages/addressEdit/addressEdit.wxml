<view class="page">
  <view class="formCard">
    <view class="field">
      <view class="label">收货人</view>
      <input class="input" value="{{receiverName}}" data-field="receiverName" bindinput="onInput" placeholder="请填写收货人姓名" />
    </view>

    <view class="field">
      <view class="label">手机号</view>
      <input class="input" value="{{receiverPhone}}" data-field="receiverPhone" bindinput="onInput" placeholder="请填写收货手机号" type="number" />
    </view>

    <view class="field">
      <view class="label">省份</view>
      <input class="input" value="{{province}}" data-field="province" bindinput="onInput" placeholder="请填写省份" />
    </view>

    <view class="field">
      <view class="label">城市</view>
      <input class="input" value="{{city}}" data-field="city" bindinput="onInput" placeholder="请填写城市" />
    </view>

    <view class="field">
      <view class="label">区县</view>
      <input class="input" value="{{district}}" data-field="district" bindinput="onInput" placeholder="请填写区县" />
    </view>

    <view class="field">
      <view class="label">详细地址</view>
      <textarea class="textarea" value="{{detailAddress}}" data-field="detailAddress" bindinput="onInput" placeholder="请填写街道、门牌号等详细地址" />
    </view>

    <view class="field">
      <view class="label">邮编</view>
      <input class="input" value="{{postalCode}}" data-field="postalCode" bindinput="onInput" placeholder="选填" />
    </view>

    <view class="switchRow">
      <view class="label">设为默认地址</view>
      <switch checked="{{isDefault}}" bindchange="onDefaultChange" color="#57984a" />
    </view>
  </view>

  <button class="saveBtn" loading="{{loading}}" bindtap="onSave">保存地址</button>
</view>
