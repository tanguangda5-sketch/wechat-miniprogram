.page { min-height:100vh; background:#fff; padding:28rpx 24rpx; box-sizing:border-box; }
.header { font-size:40rpx; font-weight:700; color:#111; margin-bottom:24rpx; }
.title-input { height:84rpx; padding:0 24rpx; border-radius:20rpx; background:#f6f7f9; font-size:30rpx; }
.content-input { width:100%; height:360rpx; margin-top:20rpx; padding:24rpx; border-radius:24rpx; background:#f6f7f9; font-size:28rpx; line-height:1.7; box-sizing:border-box; }
.tips { margin-top:18rpx; font-size:24rpx; line-height:1.7; color:#8c8c8c; }
.submit-btn { margin-top:28rpx; height:88rpx; border-radius:24rpx; background:#ff4f8a; color:#fff; font-size:30rpx; font-weight:700; line-height:88rpx; text-align:center; }
