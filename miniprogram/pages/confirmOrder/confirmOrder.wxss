.page {
  min-height: 100vh;
  background: #f6faf4;
  padding: 24rpx 24rpx 180rpx;
  box-sizing: border-box;
}

.sectionCard {
  margin-bottom: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 12rpx 30rpx rgba(55, 42, 26, 0.06);
}

.receiverRow {
  display: flex;
  gap: 18rpx;
  align-items: center;
}

.receiver {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2a1f;
}

.phone {
  font-size: 26rpx;
  color: #667566;
}

.addressText,
.emptyAddress {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #233123;
}

.sectionTitle {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2a1f;
}

.goodsItem {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 22rpx;
}

.goodsCover {
  width: 132rpx;
  height: 132rpx;
  border-radius: 18rpx;
  background: #eef5ea;
  flex-shrink: 0;
}

.goodsBody {
  min-width: 0;
  flex: 1;
}

.goodsTitle {
  font-size: 28rpx;
  color: #1f2a1f;
  font-weight: 700;
  line-height: 1.5;
}

.goodsMeta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8b94a1;
}

.goodsPrice {
  font-size: 28rpx;
  color: #57984a;
  font-weight: 700;
}

.remarkInput {
  width: 100%;
  min-height: 160rpx;
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: #f4f7f2;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #1f2a1f;
}

.amountRow {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #233123;
}

.amountRow + .amountRow {
  margin-top: 18rpx;
}

.amountRow.total {
  font-weight: 700;
  color: #1f2a1f;
}

.bottomBar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx calc(env(safe-area-inset-bottom) + 20rpx);
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 26rpx rgba(55, 42, 26, 0.08);
}

.payLabel {
  font-size: 22rpx;
  color: #8b94a1;
}

.payValue {
  margin-top: 8rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2a1f;
}

.submitBtn {
  min-width: 260rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  background: #57984a;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.submitBtn::after {
  border: none;
}
