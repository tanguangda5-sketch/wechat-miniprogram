.page {
  min-height: 100vh;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f6faf4 0%, #edf5ea 18%, #f8fbf7 100%);
}

.page.mode-ask {
  background:
    radial-gradient(circle at top right, rgba(183, 149, 255, 0.18), transparent 28%),
    radial-gradient(circle at top left, rgba(255, 215, 138, 0.2), transparent 24%),
    linear-gradient(180deg, #fbf5ff 0%, #ffffff 32%, #fafafc 100%);
}

.customNav {
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 10rpx;
}

.topbar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 78rpx;
}

.content {
  padding: 8rpx 24rpx 40rpx;
}

.backBtn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
  z-index: 2;
}

.backArrow {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #1f1f1f;
  border-bottom: 4rpx solid #1f1f1f;
  transform: rotate(45deg);
}

.modeTabs {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-shrink: 0;
}

.modeTab {
  position: relative;
  padding-bottom: 6rpx;
  color: #8b8b8b;
  font-size: 36rpx;
  font-weight: 700;
}

.modeTab.active {
  color: #1f1f1f;
}

.modeTab.active::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 4rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #57984a 0%, #57984a 100%);
}

.page.mode-ask .modeTab.active::after {
  background: linear-gradient(90deg, #7e63ff 0%, #b46cff 100%);
}

.modeBadge {
  max-width: 260rpx;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  font-size: 19rpx;
  color: #ffffff;
  background: linear-gradient(90deg, #5fa7ff 0%, #b46cff 100%);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex-shrink: 1;
}

.searchPanel,
.askPanel {
  margin-bottom: 26rpx;
}

.searchInputWrap {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 74rpx;
  padding: 6rpx 8rpx 6rpx 20rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 4rpx solid #d7e8d3;
  box-shadow: 0 16rpx 32rpx rgba(87, 152, 74, 0.08);
}

.searchInput {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #1f1f1f;
}

.searchPlaceholder,
.askPlaceholder {
  color: #b3b3b3;
}

.voiceIconBtn,
.voiceMiniBtn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f7f7f7;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}

.micStem {
  width: 14rpx;
  height: 20rpx;
  border: 3rpx solid #8d8d8d;
  border-bottom: none;
  border-radius: 18rpx 18rpx 8rpx 8rpx;
}

.micBase {
  position: absolute;
  bottom: 11rpx;
  width: 20rpx;
  height: 6rpx;
  border-bottom: 3rpx solid #8d8d8d;
  border-left: 3rpx solid transparent;
  border-right: 3rpx solid transparent;
}

.searchBtn {
  flex-shrink: 0;
  min-width: 100rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  text-align: center;
  background: linear-gradient(90deg, #57984a 0%, #57984a 100%);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.askInputWrap {
  padding: 16rpx 18rpx 14rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 3rpx solid rgba(122, 93, 234, 0.72);
  box-shadow: 0 20rpx 40rpx rgba(140, 104, 255, 0.1);
}

.askInput {
  width: 100%;
  min-height: 84rpx;
  font-size: 27rpx;
  line-height: 1.45;
  color: #1f1f1f;
}

.askActions {
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.deepThinkBtn {
  padding: 10rpx 20rpx;
  border-radius: 22rpx;
  background: #f0eaff;
  color: #6d56d6;
  font-size: 24rpx;
  line-height: 1.2;
}

.deepThinkBtn.active {
  background: linear-gradient(90deg, #7e63ff 0%, #b46cff 100%);
  color: #ffffff;
}

.askRightActions {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.sendBtn {
  padding: 14rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(90deg, #7da6ff 0%, #b46cff 100%);
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.2;
}

.section {
  margin-bottom: 34rpx;
}

.sectionHead {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.sectionTitle {
  color: #1f1f1f;
  font-size: 28rpx;
  font-weight: 600;
}

.sectionTitle.hot {
  color: #57984a;
}

.sectionAction {
  color: #8f8f8f;
  font-size: 24rpx;
}

.historyDoneBtn {
  padding: 6rpx 0;
  color: #9a9a9a;
}

.historyManageIcon {
  width: 60rpx;
  height: 60rpx;
  flex-shrink: 0;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  max-width: 100%;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #edf5ea;
  color: #516250;
  font-size: 26rpx;
}

.hotList {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.hotCard {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 20rpx 40rpx rgba(45, 45, 45, 0.06);
}

.hotInfo {
  flex: 1;
  min-width: 0;
}

.hotCardTitle {
  color: #1f1f1f;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.45;
}

.hotBadge {
  margin-top: 8rpx;
  color: #57984a;
  font-size: 22rpx;
}

.hotDesc {
  margin-top: 16rpx;
  color: #737373;
  font-size: 24rpx;
  line-height: 1.6;
}

.hotImage {
  width: 152rpx;
  height: 152rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
}

.resultHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.resultSummary {
  color: #1f1f1f;
  font-size: 30rpx;
  font-weight: 600;
}

.resultReset {
  color: #57984a;
  font-size: 26rpx;
}

.resultTabs {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.resultTab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  background: #edf5ea;
  color: #667566;
  font-size: 27rpx;
}

.resultTab.active {
  background: #2f5f3a;
  color: #ffffff;
}

.resultList {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.resultCard {
  display: flex;
  align-items: stretch;
  border-radius: 20rpx;
  overflow: hidden;
  background: #f7fbf5;
  box-shadow: 0 18rpx 36rpx rgba(28, 28, 28, 0.06);
}

.resultImage {
  width: 180rpx;
  flex-shrink: 0;
  display: block;
}

.resultCard--activity,
.resultCard--scenic,
.resultCard--hotel {
  min-height: 276rpx;
}

.resultCard--product {
  min-height: 180rpx;
}

.resultImage--activity,
.resultImage--scenic,
.resultImage--hotel {
  height: 276rpx;
}

.resultImage--product {
  height: 180rpx;
}

.resultBody {
  flex: 1;
  min-width: 0;
  padding: 18rpx 20rpx;
  display: flex;
  flex-direction: column;
}

.resultTitleRow {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.resultType {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef3eb;
  color: #5f7260;
  font-size: 22rpx;
}

.resultTitle {
  flex: 1;
  min-width: 0;
  color: #1f2a1f;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.tagRow {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.resultDayTag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #57984a;
  color: #ffffff;
  font-size: 22rpx;
}

.resultTag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #edf5ea;
  color: #426046;
  font-size: 22rpx;
}

.resultFooter {
  margin-top: auto;
  padding-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.resultPrice {
  flex-shrink: 0;
  color: #57984a;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 700;
}

.resultSold {
  font-size: 22rpx;
  color: #8ea08b;
  text-align: right;
}

.emptyBlock {
  padding: 80rpx 36rpx;
  text-align: center;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #909090;
  font-size: 28rpx;
}

.historyCard {
  padding: 12rpx 20rpx 10rpx;
  border-radius: 28rpx;
  background: rgba(245, 245, 255, 0.86);
}

.historyRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 6rpx;
  border-bottom: 1rpx solid rgba(125, 125, 125, 0.12);
}

.historyRow:last-child {
  border-bottom: none;
}

.historyQuestion {
  flex: 1;
  color: #333333;
  font-size: 26rpx;
  line-height: 1.5;
}

.historyTime {
  flex-shrink: 0;
  color: #9a9a9a;
  font-size: 23rpx;
}

.historyDelete {
  flex-shrink: 0;
  width: 44rpx;
  text-align: center;
  color: #b0b0b0;
  font-size: 40rpx;
  line-height: 1;
}

.historyToggle {
  padding-top: 16rpx;
  color: #8d8d8d;
  font-size: 24rpx;
  line-height: 1.4;
  text-align: center;
}

.skillGrid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
}

.skillCard {
  min-height: 126rpx;
  padding: 14rpx 14rpx 12rpx;
  border-radius: 24rpx;
  background: rgba(246, 245, 255, 0.95);
  box-shadow: 0 16rpx 28rpx rgba(114, 90, 151, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.skillIcon {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
}

.skillTitle {
  color: #262626;
  font-size: 23rpx;
  font-weight: 400;
  text-align: center;
}

.askSuggestionList {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.askSuggestion {
  align-self: flex-start;
  max-width: 92%;
  padding: 18rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(244, 241, 255, 0.95);
  color: #4a4280;
  font-size: 26rpx;
  line-height: 1.6;
}
