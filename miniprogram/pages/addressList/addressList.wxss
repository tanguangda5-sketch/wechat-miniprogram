.page {
  min-height: 100vh;
  background: #f6faf4;
  padding: 24rpx 24rpx 140rpx;
  box-sizing: border-box;
}

.emptyWrap {
  padding: 180rpx 24rpx 60rpx;
  text-align: center;
}

.emptyTitle {
  font-size: 36rpx;
  font-weight: 700;
  color: #233123;
}

.emptyDesc {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #8b94a1;
}

.addressCard {
  margin-bottom: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 12rpx 30rpx rgba(55, 42, 26, 0.06);
}

.headRow {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.receiver {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2a1f;
}

.phone {
  font-size: 26rpx;
  color: #667566;
}

.defaultTag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #edf5ea;
  color: #57984a;
  font-size: 22rpx;
}

.addressText {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #233123;
}

.actions {
  display: flex;
  gap: 24rpx;
  margin-top: 20rpx;
}

.action {
  font-size: 24rpx;
  color: #667566;
}

.action.danger {
  color: #c36d6d;
}

.addBtn {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(env(safe-area-inset-bottom) + 20rpx);
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  background: #57984a;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.addBtn::after {
  border: none;
}
